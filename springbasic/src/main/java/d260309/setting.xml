<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
<!-- person정보 객체를 생성하고 이 정보를 ConsolePrint 객체 DI -->

<bean id="person" class="d260309.Person">
<property name="id" value="020110-3456789"></property>
<property name="name" value="홍길동"></property>
<property name="address" value="서울시 중랑구"></property>
</bean>

<bean id="consoleprint" class="d260309.ConsolePrint">
<property name="person" ref="person"></property>
</bean>

<bean id="gridprint" class="d260309.GridPrint">
<property name="p" ref="person"></property>
</bean>
</beans>
